{
  "name": "@vocab/vite",
  "version": "1.0.0",
  "author": "SEEK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seek-oss/vocab.git",
    "directory": "packages/vite"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "@vocab-private/monorepo": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./chunks": {
      "@vocab-private/monorepo": "./src/chunks.ts",
      "import": "./dist/chunks.mjs",
      "require": "./dist/chunks.cjs"
    },
    "./get-chunk-name": {
      "@vocab-private/monorepo": "./src/get-chunk-name.ts",
      "import": "./dist/get-chunk-name.mjs",
      "require": "./dist/get-chunk-name.cjs"
    },
    "./runtime": {
      "@vocab-private/monorepo": "./src/runtime.ts",
      "import": "./dist/runtime.mjs",
      "require": "./dist/runtime.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@vocab/core": "workspace:^",
    "cjs-module-lexer": "^2.0.0",
    "debug": "^4.3.1",
    "es-module-lexer": "^2.0.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.5",
    "rolldown": "^1.0.0-rc.9",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./chunks": {
        "import": "./dist/chunks.mjs",
        "require": "./dist/chunks.cjs"
      },
      "./get-chunk-name": {
        "import": "./dist/get-chunk-name.mjs",
        "require": "./dist/get-chunk-name.cjs"
      },
      "./runtime": {
        "import": "./dist/runtime.mjs",
        "require": "./dist/runtime.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "inlinedDependencies": {
    "rolldown": "1.0.0-rc.9"
  }
}
